# Environment Variables — Bishop Martin Parent Portal
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.

# ── Database ──────────────────────────────────────────────
# You can connect using either individual fields OR a DATABASE_URL connection string.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_NAME=parentportal

# Optional: Connection string (takes precedence over the fields above)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/parentportal

# Optional: Enable SSL connection (required by Neon, Render, Supabase, AWS RDS, etc.)
DB_SSL=false

# ── API Server ────────────────────────────────────────────
PORT=3000

# ── Security ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# ── Node Environment ──────────────────────────────────────
NODE_ENV=development

# ── Email Service (SMTP) ──────────────────────────────────
# Leave blank to fall back to Ethereal Mail for local testing/development.
# Fill in to send actual emails in production.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password_here
# SMTP_FROM="Bishop Martin IT Dept" <no-reply@bmhs.edu.bz>
